DATABASE_URL=sqlite:///./job_matching.db
FRONTEND_ORIGIN=http://localhost:3000
BACKEND_BASE_URL=http://127.0.0.1:8000
TRACKING_SECRET=change-me
EMAIL_CLICK_BOOST=0.08
EMAIL_CLICK_COOLDOWN_HOURS=24
EMAIL_CLICK_TOKEN_TTL_HOURS=72
TOKEN_EXPIRE_MINUTES=1440
MAX_EVENT_RETRY=3
PASSIVE_THROTTLE_HOURS=24
SCORE_W1=0.5
SCORE_W2=0.3
SCORE_W3=0.2
BEHAVIOR_LAMBDA=0.12
BEHAVIOR_PASSIVE_STREAK=3
BEHAVIOR_INACTIVE_STREAK=6
# Matching strategy: proficiency | tfidf | embedding | gemini | set
MATCHING_STRATEGY=proficiency
COHERE_API_KEY=
COHERE_EMBED_MODEL=embed-multilingual-v3.0

# Google Gemini API (enables AI-powered CV parsing and embedding matching)
GEMINI_API_KEY=
# OpenRouter API (alternative CV parser provider)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# CV parser mode: auto (prefer OpenRouter, then Gemini) | openrouter | gemini | regex
CV_PARSER_MODE=auto

# SMTP email (for sending real notification emails)
# Gmail: use App Password from https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=JobMatch AI
